#!/usr/bin/env bash
# Namu claude wrapper — injects hooks and session tracking
#
# When running inside a Namu terminal (NAMU_SURFACE_ID is set), this wrapper
# intercepts `claude` invocations to inject --session-id and --settings flags
# so that Claude Code hooks fire back into Namu for notifications/status.
# Outside Namu, it passes through to the real claude binary unchanged.

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Return 0 only when NAMU_SOCKET points to a live Namu socket.
namu_socket_available() {
    local socket="${NAMU_SOCKET:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir namu_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    namu_bin="$self_dir/namu"
    [[ -x "$namu_bin" ]] || namu_bin="$(command -v namu || true)"
    [[ -n "$namu_bin" ]] || return 1

    NAMU_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$namu_bin" --socket "$socket" system ping >/dev/null 2>&1
}

# Pass through if not in a Namu terminal, hooks are disabled, or the
# socket is unavailable (stale env / app not running).
IN_NAMU=0
if [[ -n "${NAMU_SURFACE_ID:-}" ]]; then
    IN_NAMU=1
fi

if [[ "$IN_NAMU" == "0" || "${NAMU_CLAUDE_HOOKS_DISABLED:-}" == "1" ]] || ! namu_socket_available; then
    if [[ "$IN_NAMU" == "1" ]]; then
        unset CLAUDECODE
    fi
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

# Find real claude.
REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support session/hook flags.
case "${1:-}" in
    mcp|config|api-key|rc|remote-control) exec "$REAL_CLAUDE" "$@" ;;
esac

# Unset CLAUDECODE to avoid "nested session" detection — Namu terminals are
# independent sessions even when the parent shell was launched from Claude Code.
unset CLAUDECODE

# Check if the user already specified a session/resume flag.
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|-r|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Export the wrapper's PID for stale-session detection.
export NAMU_CLAUDE_PID=$$

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
HOOKS_JSON='{"hooks":{"SessionStart":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook session-start","timeout":10}]}],"Stop":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook stop","timeout":10}]}],"SessionEnd":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook session-end","timeout":1}]}],"Notification":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook notification","timeout":10}]}],"UserPromptSubmit":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook prompt-submit","timeout":10}]}],"PreToolUse":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook pre-tool-use","timeout":5,"async":true}]}],"PermissionRequest":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook permission-request","timeout":10}]}],"SubagentStop":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook subagent-stop","timeout":5,"async":true}]}],"TaskCompleted":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook task-completed","timeout":5,"async":true}]}],"TeammateIdle":[{"matcher":"","hooks":[{"type":"command","command":"namu claude-hook teammate-idle","timeout":5,"async":true}]}]}}'

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
